# Symfony — surcharge prod (par rapport à backend/.env)
#   cp .env.prod.example .env.prod
# Ne pas committer backend/.env.prod
#
# Chargé automatiquement quand APP_ENV=prod (fichier monté dans le conteneur).
# Ne mettre ici que ce qui change en production.

