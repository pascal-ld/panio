# Copier en .env pour le dev local :
#   cp .env.example .env
#
# Production :
#   cp .env.prod.example .env.prod
#   cp backend/.env.prod.example backend/.env.prod

# Fichiers Compose à charger (dev)
COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml

# Réseau Docker externe (Traefik)
DOCKER_NETWORK=lino

# Domaines Traefik (Host rules)
FRONTEND_HOST=panio.local
BACKEND_HOST=back.panio.local
MAIL_HOST=mail.panio.local
PMA_HOST=pma.panio.local

# URLs publiques (emails, liens absolus)
FRONTEND_URL=http://panio.local
BACKEND_URL=http://back.panio.local
NEXT_PUBLIC_API_URL=http://back.panio.local

# Mailpit (dev uniquement — lien affiché après inscription)
NEXT_PUBLIC_MAIL_URL=http://mail.panio.local

# Traefik
TRAEFIK_ENTRYPOINT=web

# Backend Symfony
APP_ENV=dev
APP_FRONTEND_URL=http://panio.local
APP_BACKEND_URL=http://back.panio.local
CORS_ALLOW_ORIGIN=^https?://panio\.local
MAILER_DSN=smtp://panio-mailpit:1025
MAILER_FROM=Panio <noreply@panio.local>
JWT_TOKEN_TTL=2592000

# MariaDB
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=panio
MYSQL_USER=app
MYSQL_PASSWORD=app
DATABASE_URL=mysql://app:app@panio-mariadb:3306/panio?serverVersion=11.4.0-MariaDB&charset=utf8mb4
