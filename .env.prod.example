# Docker Compose — production (racine du projet)
#   cp .env.prod.example .env.prod
# Ne pas committer .env.prod
#
# Config Symfony : backend/.env.prod (voir backend/.env.prod.example)

COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
DOCKER_NETWORK=lino

FRONTEND_HOST=panio.app
BACKEND_HOST=back.panio.app

FRONTEND_URL=https://panio.app
BACKEND_URL=https://back.panio.app
NEXT_PUBLIC_API_URL=https://back.panio.app
NEXT_PUBLIC_MAIL_URL=

TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

APP_ENV=prod

MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=panio
MYSQL_USER=app
MYSQL_PASSWORD=change_me_app
